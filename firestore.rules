rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lots are public to view, only admin can modify
    match /lots/{lotId} {
      allow read: if true;
      allow write: if false; // Only admin via backend/dashboard (simplified for this demo)
      
      match /bids/{bidId} {
        allow read: if true;
        allow create: if true; // In a real app we'd check auth token
      }
    }
    
    // Applications queue
    match /applications/{appId} {
      allow create: if true;
      allow read, update, delete: if false; // Only admin
    }
  }
}
